# Neon dashboard > Connect > Connection string
# 実際の接続文字列は .env.local にだけ保存し、このファイルへは書き込まないこと。
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_NEON_HOST/neondb?sslmode=require
AUTH_JWT_SECRET=generate_a_long_random_secret_at_least_32_characters

# Public URL for the Socket.IO server when using the hosted web app.
VITE_SOCKET_URL=https://YOUR_SOCKET_SERVER.example.com

# Optional TURN server for WebRTC calls that cannot connect through STUN alone.
# These are served at runtime so they can also be configured in Render without a client rebuild.
TURN_URL=turns:turn.example.com:5349
TURN_USERNAME=YOUR_TURN_USERNAME
TURN_CREDENTIAL=YOUR_TURN_CREDENTIAL

# Optional YouTube Data API key for in-app search. URL and playlist sharing work without it.
YOUTUBE_API_KEY=YOUR_YOUTUBE_DATA_API_KEY
