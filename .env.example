# Neon dashboard > Connect > Connection string
# 実際の接続文字列は .env.local にだけ保存し、このファイルへは書き込まないこと。
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_NEON_HOST/neondb?sslmode=require
AUTH_JWT_SECRET=generate_a_long_random_secret_at_least_32_characters

# Public URL for the Socket.IO server when using the hosted web app.
VITE_SOCKET_URL=https://YOUR_SOCKET_SERVER.example.com
