{
  "name": "hidegames",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test:mahjong": "node scripts/test-mahjong.cjs",
    "preview": "vite preview",
    "desktop": "node scripts/check-port.cjs 3001 && concurrently -k \"npm run server\" \"vite --host 127.0.0.1 --port 5173\" \"wait-on tcp:3001 http://127.0.0.1:5173 && electron .\"",
    "server": "node --env-file-if-exists=.env.local server/index.cjs",
    "online": "concurrently -k \"npm run server\" \"vite --host 0.0.0.0\""
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "latest",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "latest",
    "react-dom": "latest",
    "react-icons": "^5.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "wait-on": "latest"
  }
}
